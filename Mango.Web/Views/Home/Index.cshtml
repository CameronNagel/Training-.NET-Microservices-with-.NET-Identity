@model List<Mango.Web.DTOs.ProductDto>

@{
    ViewData["Title"] = "Home";
}

<style>
    .product-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        cursor: pointer;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15) !important;
        }

            .product-card:hover .card-img-top {
                filter: brightness(1.05);
                transition: filter 0.25s ease;
            }

            .product-card:hover .card-title {
                color: #0d6efd;
                transition: color 0.25s ease;
            }

        .product-card .card-img-top {
            transition: filter 0.25s ease;
        }

        .product-card .card-title {
            transition: color 0.25s ease;
        }

    #productModal .modal-img {
        width: 100%;
        max-height: 320px;
        object-fit: cover;
        border-radius: 8px;
    }

    #productModal .modal-img-placeholder {
        width: 100%;
        height: 220px;
        background-color: #6c757d;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
    }

    #productModal .price-tag {
        font-size: 1.5rem;
        font-weight: 700;
        color: #198754;
    }
</style>

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Our Products</h1>
        <p class="text-muted">Browse our full selection of products</p>
    </div>

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            No products are currently available.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm product-card"
                         onclick="openProductModal(
                                     @product.ProductId,
                                     '@Html.Raw(Html.Encode(product.Name))',
                                     '@Html.Raw(Html.Encode(product.CategoryName))',
                                     '@Html.Raw(Html.Encode(product.Description))',
                                     @product.Price,
                                     '@product.ImageUrl'
                                 )">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl"
                                 class="card-img-top"
                                 alt="@product.Name"
                                 style="height: 220px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary d-flex align-items-center justify-content-center"
                                 style="height: 220px;">
                                <span class="text-white fs-4">No Image</span>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-primary mb-2 align-self-start">@product.CategoryName</span>
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted flex-grow-1">@product.Description</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fs-5 fw-bold text-success">@product.Price.ToString("C")</span>
                                <button class="btn btn-outline-primary btn-sm"
                                        onclick="event.stopPropagation(); openProductModal(
                                                    @product.ProductId,
                                                    '@Html.Raw(Html.Encode(product.Name))',
                                                    '@Html.Raw(Html.Encode(product.CategoryName))',
                                                    '@Html.Raw(Html.Encode(product.Description))',
                                                    @product.Price,
                                                    '@product.ImageUrl'
                                                )">
                                    View Details
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Product Detail Modal -->
<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-0">
                <div class="row g-4">
                    <div class="col-md-5">
                        <div id="modal-img-container"></div>
                    </div>
                    <div class="col-md-7 d-flex flex-column justify-content-center">
                        <span id="modal-category" class="badge bg-primary mb-2 align-self-start"></span>
                        <h3 id="modal-name" class="fw-bold mb-2"></h3>
                        <p id="modal-description" class="text-muted mb-4"></p>
                        <div class="d-flex align-items-center justify-content-between">
                            <span id="modal-price" class="price-tag"></span>
                            <button type="button" class="btn btn-primary px-4">Add to Cart</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openProductModal(id, name, category, description, price, imageUrl) {
            document.getElementById('modal-name').textContent = name;
            document.getElementById('modal-category').textContent = category;
            document.getElementById('modal-description').textContent = description;
            document.getElementById('modal-price').textContent = new Intl.NumberFormat('en-US', {
                style: 'currency', currency: 'USD'
            }).format(price);

            const imgContainer = document.getElementById('modal-img-container');
            if (imageUrl && imageUrl.trim() !== '') {
                imgContainer.innerHTML = `<img src="${imageUrl}" alt="${name}" class="modal-img" />`;
            } else {
                imgContainer.innerHTML = `<div class="modal-img-placeholder">No Image</div>`;
            }

            const modal = new bootstrap.Modal(document.getElementById('productModal'));
            modal.show();
        }
    </script>
}